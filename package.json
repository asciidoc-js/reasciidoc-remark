{
  "name": "@asciidoc-js/reasciidoc-remark",
  "version": "0.1.1",
  "description": "reasciidoc plugin to transform to remark",
  "license": "MIT",
  "keywords": [
    "unist",
    "adast",
    "mdast",
    "asciidoc",
    "markdown",
    "ast",
    "syntax-tree",
    "converter",
    "remark",
    "reasciidoc"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test test/*.test.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@asciidoc-js/adast": "^1.0.0",
    "unified": "^11.0.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/unist": "^3.0.3",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vfile": "^6.0.3"
  }
}
